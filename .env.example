# --- APP MODE ---
# "local"  = OSS single-user: SQLite, no login, no Stripe (just bring an LLM key below).
# "hosted" = full product: Supabase auth + Stripe credits.
# Use NEXT_PUBLIC_ so the browser and server agree (client components call isLocal()).
# If unset: inferred as "hosted" when NEXT_PUBLIC_SUPABASE_URL is present, else "local".
NEXT_PUBLIC_APP_MODE=local
# Optional server-only alias if you cannot set NEXT_PUBLIC_APP_MODE:
# APP_MODE=local

# Canonical list of environment variables. Copy to .env.local and fill in.
# Boot validation lives in src/lib/env.ts, keep these in sync.

# --- CORE (required in every environment) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider. Default "gemini"; set "compatible" for any OpenAI-style endpoint.
LLM_PROVIDER=gemini
# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Required when LLM_PROVIDER=compatible (base URL/model have defaults)
LLM_API_KEY=
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-flash
# Set to false if your gateway rejects response_format
# LLM_JSON_MODE=false

# --- PROD_REQUIRED (required in production, optional in dev) ---
# SHA-256 hash of the admin secret (never the plaintext). See src/lib/admin-auth.ts
ADMIN_SECRET_HASH=
NEXT_PUBLIC_SITE_URL=

# --- STRIPE (DISABLED for now: free daily credits only, no purchase flow) ---
# Fill these and re-enable the checkout UI to turn paid credits back on.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- RECOMMENDED (degrade gracefully; prod warns if missing) ---
# Either one enables Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Cloudflare Turnstile CAPTCHA
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- SEO / Google (optional) ---
# Search Console HTML-tag verification: paste ONLY the content= value, not the whole <meta> tag.
# Example Google shows: <meta name="google-site-verification" content="AbCdEf123..." />
# Put just: AbCdEf123...
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# GA4 measurement ID (G-XXXXXXXXXX). Leave unset to skip analytics.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- OPTIONAL ---
# LLM_RATE_LIMIT_USER=8
# LLM_RATE_LIMIT_IP=20
# LLM_RATE_LIMIT_WINDOW_SEC=60
# POSTHOG_API_KEY=
# POSTHOG_HOST=
# ALERT_WEBHOOK_URL=
# Global LLM circuit breaker: max LLM requests across ALL users/IPs per window.
# 0 = disabled. Set a ceiling (e.g. 300) in prod to cap spend under a distributed burst.
# LLM_RATE_LIMIT_GLOBAL=0
